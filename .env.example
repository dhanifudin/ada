# Supabase project used by the rdosen4 web platform (see ../rdosen4/supabase/schema.sql)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY
# ^ service_role key: keep this secret. It bypasses RLS and must never be
#   committed, logged, or shipped to the web frontend (that uses the anon key).

# All attendance objects live in the `dosen4` Postgres schema, not `public`.
# Must also be added to Supabase Dashboard -> Project Settings -> API ->
# "Exposed schemas", or the RPC call will 404.
SUPABASE_SCHEMA=dosen4

# Identifies this agent instance in logs (useful if you run more than one)
AGENT_ID=ada-agent-campus-1

# arp_scan    -> active scan, needs cap_net_raw or root (see README)
# neigh_table -> unprivileged fallback, reads the OS ARP/neighbor table
# controller  -> not implemented yet (future WiFi controller/AP API)
DETECTOR=neigh_table

# How often to scan, and how long a MAC can go unseen before it's
# considered absent (also enforced server-side by the Supabase RPC).
SCAN_INTERVAL=30
PRESENCE_TIMEOUT=120

# Used by neigh_table's optional ping sweep (and a hint for future
# controller-based detectors). Leave blank to disable the sweep.
SUBNET_CIDR=192.168.1.0/24
PING_SWEEP=true

# Only used by DETECTOR=arp_scan; leave blank to let arp-scan auto-pick.
ARP_SCAN_INTERFACE=
